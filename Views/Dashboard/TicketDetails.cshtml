@model TicketingSystem_DotNetMVC.Models.Ticket
@{
    ViewData["Title"] = "Ticket #" + Model.TicketId + " - TicketSphere";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <a href="@Url.Action("MyTickets", "Dashboard")" class="btn btn-outline-secondary btn-sm mb-3">
                <i class="fas fa-arrow-left"></i> Back to Tickets
            </a>
            <h1 class="page-title"><i class="fas fa-ticket-alt text-primary me-2"></i>Ticket #@Model.TicketId</h1>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <!-- Ticket Details -->
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Ticket Details</h5>
                    <div>
                        @{
                            var statusBadgeClass = Model.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.Open ? "primary" :
                                                 Model.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.InProgress ? "warning" :
                                                 "success";
                        }
                        <span class="badge bg-@statusBadgeClass">@Model.Status</span>
                    </div>
                </div>
                <div class="card-body p-4">
                    <h3 class="fw-bold mb-4">@Model.Title</h3>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <p class="text-muted small mb-1"><i class="fas fa-flag"></i> Priority</p>
                            @{
                                var priorityClass = Model.Priority == TicketingSystem_DotNetMVC.Models.TicketPriority.High ? "danger" :
                                                   Model.Priority == TicketingSystem_DotNetMVC.Models.TicketPriority.Medium ? "warning" :
                                                   "info";
                            }
                            <p class="fw-bold">
                                <span class="badge bg-@priorityClass">@Model.Priority</span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted small mb-1"><i class="fas fa-calendar"></i> Created Date</p>
                            <p class="fw-bold">@Model.CreatedDate.ToString("dd MMM yyyy, hh:mm tt")</p>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <p class="text-muted small mb-1"><i class="fas fa-sync"></i> Last Updated</p>
                            <p class="fw-bold">@(Model.UpdatedDate?.ToString("dd MMM yyyy, hh:mm tt") ?? "Not updated yet")</p>
                        </div>
                        @if(Model.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.Closed)
                        {
                            <div class="col-md-6">
                                <p class="text-muted small mb-1"><i class="fas fa-check"></i> Closed Date</p>
                                <p class="fw-bold">@(Model.ClosedDate?.ToString("dd MMM yyyy, hh:mm tt") ?? "N/A")</p>
                            </div>
                        }
                    </div>

                    <hr>

                    <h6 class="fw-bold mb-3"><i class="fas fa-align-left"></i> Description</h6>
                    <div class="card border-0" role="alert" style="background:#f8fafc;">
                        <div class="card-body p-3">
                        <p class="mb-0" style="white-space: pre-wrap;">@Model.Description</p>
                        </div>
                    </div>

                    @if(!string.IsNullOrEmpty(Model.AssignedAgent?.FullName))
                    {
                        <hr>
                        <h6 class="fw-bold mb-3"><i class="fas fa-user-tie"></i> Assigned Agent</h6>
                        <p class="mb-0">
                            <i class="fas fa-user-circle"></i> <strong>@Model.AssignedAgent.FullName</strong>
                        </p>
                    }
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center gap-2 flex-wrap">
                    <h5 class="mb-0"><i class="fas fa-comments me-2"></i>Activity & Updates <span class="badge bg-secondary">@Model.Comments.Count</span></h5>
                    <button type="button" class="btn btn-outline-secondary btn-sm activity-export-btn">
                        <i class="fas fa-file-export me-1"></i>Export
                    </button>
                </div>
                <div class="card-body p-4">
                    @if(Model.Comments.Any())
                    {
                        <div class="comments-section activity-timeline mb-4" style="max-height: 460px; overflow-y: auto;">
                            @foreach(var comment in Model.Comments.OrderBy(c => c.CreatedDate))
                            {
                                var userName = comment.User.FullName ?? "User";
                                var initial = userName.Substring(0, 1).ToUpper();
                                var isSystemEvent = comment.User.Role == "Agent" || comment.User.Role == "Admin";

                                <div class="activity-item @(isSystemEvent ? "system-event" : "")">
                                    <div class="activity-marker">
                                        @if (isSystemEvent)
                                        {
                                            <span class="activity-avatar system"><i class="fas fa-gear"></i></span>
                                        }
                                        else
                                        {
                                            <span class="activity-avatar">@initial</span>
                                        }
                                    </div>
                                    <div class="activity-card">
                                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                            <div class="activity-meta">
                                                <h6 class="activity-name mb-0">@comment.User.FullName</h6>
                                                <small class="activity-time">@comment.CreatedDate.ToString("dd MMM yyyy, hh:mm tt")</small>
                                            </div>
                                            <span class="badge bg-info">@comment.User.Role</span>
                                        </div>

                                        <a href="@Url.Action("TicketDetails", "Dashboard", new { id = comment.TicketId })" class="ticket-tag d-inline-flex align-items-center mb-2">
                                            <i class="fas fa-hashtag me-1"></i>Ticket #@comment.TicketId
                                        </a>

                                        <div class="activity-content" style="white-space: pre-wrap;">@comment.Message</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4"><i class="fas fa-comments"></i> No comments yet</p>
                    }

                    <hr>

                    <!-- Add Comment Form -->
                    <h6 class="fw-bold mb-3"><i class="fas fa-plus-circle"></i> Add Comment</h6>
                    <form method="post" asp-action="AddComment" asp-controller="Dashboard">
                        <input type="hidden" name="ticketId" value="@Model.TicketId">
                        <div class="mb-3">
                            <textarea name="message" class="form-control form-control-lg" rows="3"
                                      placeholder="Add your comment here..." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-paper-plane"></i> Post Comment
                        </button>
                    </form>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-chart-line me-2"></i>Ticket Timeline</h5>
                </div>
                <div class="card-body p-4">
                    @{
                        var assignedReached = Model.AssignedAgentId.HasValue;
                        var updatedReached = Model.UpdatedDate.HasValue || Model.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.InProgress || Model.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.Closed;
                        var closedReached = Model.ClosedDate.HasValue || Model.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.Closed;
                    }

                    <div class="ticket-line-graph mb-4">
                        <div class="ticket-line-progress @(closedReached ? "is-closed" : updatedReached ? "is-updated" : assignedReached ? "is-assigned" : "is-created")"></div>

                        <div class="ticket-step done">
                            <div class="ticket-step-dot"><i class="fas fa-plus"></i></div>
                            <div class="ticket-step-label">Created</div>
                            <small>@Model.CreatedDate.ToString("dd MMM yyyy")</small>
                        </div>

                        <div class="ticket-step @(assignedReached ? "done" : "")">
                            <div class="ticket-step-dot"><i class="fas fa-user-check"></i></div>
                            <div class="ticket-step-label">Assigned</div>
                            <small>@(assignedReached ? (Model.UpdatedDate?.ToString("dd MMM yyyy") ?? Model.CreatedDate.ToString("dd MMM yyyy")) : "Pending")</small>
                        </div>

                        <div class="ticket-step @(updatedReached ? "done" : "")">
                            <div class="ticket-step-dot"><i class="fas fa-pen"></i></div>
                            <div class="ticket-step-label">Updated</div>
                            <small>@(Model.UpdatedDate?.ToString("dd MMM yyyy") ?? "Pending")</small>
                        </div>

                        <div class="ticket-step @(closedReached ? "done" : "")">
                            <div class="ticket-step-dot"><i class="fas fa-check"></i></div>
                            <div class="ticket-step-label">Closed</div>
                            <small>@(Model.ClosedDate?.ToString("dd MMM yyyy") ?? "Pending")</small>
                        </div>
                    </div>

                    <h6 class="fw-bold mb-3">Full History</h6>
                    <div class="history-timeline">
                        <div class="history-item system-event">
                            <div class="activity-marker">
                                <span class="activity-avatar system"><i class="fas fa-plus"></i></span>
                            </div>
                            <div class="activity-card">
                                <h6 class="activity-name mb-1">Created</h6>
                                <p class="activity-time mb-0">@Model.CreatedDate.ToString("dd MMM yyyy, hh:mm tt")</p>
                            </div>
                        </div>

                        <div class="history-item system-event">
                            <div class="activity-marker">
                                <span class="activity-avatar system"><i class="fas fa-user-check"></i></span>
                            </div>
                            <div class="activity-card">
                                <h6 class="activity-name mb-1">Assigned</h6>
                                <p class="activity-time mb-0">
                                    @if (!string.IsNullOrEmpty(Model.AssignedAgent?.FullName))
                                    {
                                        <span>Assigned to @Model.AssignedAgent.FullName</span>
                                    }
                                    else
                                    {
                                        <span>Not assigned yet</span>
                                    }
                                </p>
                            </div>
                        </div>

                        <div class="history-item system-event">
                            <div class="activity-marker">
                                <span class="activity-avatar system"><i class="fas fa-pen"></i></span>
                            </div>
                            <div class="activity-card">
                                <h6 class="activity-name mb-1">Updated</h6>
                                <p class="activity-time mb-0">@(Model.UpdatedDate?.ToString("dd MMM yyyy, hh:mm tt") ?? "Not updated yet")</p>
                            </div>
                        </div>

                        <div class="history-item system-event">
                            <div class="activity-marker">
                                <span class="activity-avatar system"><i class="fas fa-check"></i></span>
                            </div>
                            <div class="activity-card">
                                <h6 class="activity-name mb-1">Closed</h6>
                                <p class="activity-time mb-0">@(Model.ClosedDate?.ToString("dd MMM yyyy, hh:mm tt") ?? "Not closed yet")</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="card mb-4 sticky-top" style="top: 20px;">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Quick Info</h5>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <p class="text-muted small mb-1">Status</p>
                        @{
                            var statusClass = Model.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.Open ? "danger" :
                                           Model.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.InProgress ? "warning" :
                                           "success";
                        }
                        <p class="fw-bold">
                            <span class="badge bg-@statusClass">@Model.Status</span>
                        </p>
                    </div>

                    <div class="mb-4">
                        <p class="text-muted small mb-1">Priority Level</p>
                        @{
                            var priorityBg = Model.Priority == TicketingSystem_DotNetMVC.Models.TicketPriority.High ? "danger" :
                                           Model.Priority == TicketingSystem_DotNetMVC.Models.TicketPriority.Medium ? "warning" :
                                           "info";
                        }
                        <p class="fw-bold">
                            <span class="badge bg-@priorityBg">
                                @if(Model.Priority == TicketingSystem_DotNetMVC.Models.TicketPriority.High) { <i class="fas fa-arrow-up"></i> }
                                else if(Model.Priority == TicketingSystem_DotNetMVC.Models.TicketPriority.Medium) { <i class="fas fa-minus"></i> }
                                else { <i class="fas fa-arrow-down"></i> }
                                @Model.Priority
                            </span>
                        </p>
                    </div>

                    <div class="mb-4">
                        <p class="text-muted small mb-1">Ticket ID</p>
                        <p class="fw-bold fs-5">#@Model.TicketId</p>
                    </div>

                    <div class="mb-4">
                        <p class="text-muted small mb-1">Created by</p>
                        <p class="fw-bold">@Model.User.FullName</p>
                    </div>

                    <hr>

                    <a href="@Url.Action("MyTickets", "Dashboard")" class="btn btn-outline-primary w-100">
                        <i class="fas fa-arrow-left"></i> Back to Tickets
                    </a>
                </div>
            </div>

            @if(Model.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.Closed && Model.Rating == 0)
            {
                <div class="card border-top border-success">
                    <div class="card-header bg-success bg-opacity-10">
                        <h5 class="mb-0 fw-bold text-success"><i class="fas fa-star"></i> Rate & Feedback</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small">Help us improve our service</p>
                        <form method="post" asp-action="RateTicket" asp-controller="Dashboard">
                            <input type="hidden" name="ticketId" value="@Model.TicketId">
                            
                            <div class="mb-3">
                                <label class="form-label fw-bold">Your Rating</label>
                                <div class="rating mb-3">
                                    @for(int i = 1; i <= 5; i++)
                                    {
                                        <input type="radio" name="rating" value="@i" id="star@i" required style="display: none;">
                                        <label for="star@i" class="star-label" style="cursor: pointer; font-size: 1.5rem; color: #ddd;">
                                            <i class="fas fa-star"></i>
                                        </label>
                                    }
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Feedback (Optional)</label>
                                <textarea name="feedback" class="form-control" rows="3" placeholder="Tell us about your experience..."></textarea>
                            </div>

                            <button type="submit" class="btn btn-success w-100">
                                <i class="fas fa-check-circle"></i> Submit Feedback
                            </button>
                        </form>
                    </div>
                </div>
            }
            else if(Model.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.Closed && Model.Rating > 0)
            {
                <div class="card border-top border-success">
                    <div class="card-header bg-success bg-opacity-10">
                        <h5 class="mb-0 fw-bold text-success"><i class="fas fa-star"></i> Your Feedback</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <p class="text-muted small mb-2">Your Rating:</p>
                            <div>
                                @for(int i = 0; i < Model.Rating; i++)
                                {
                                    <i class="fas fa-star text-warning" style="font-size: 1.2rem;"></i>
                                }
                                @for(int i = (int)Model.Rating; i < 5; i++)
                                {
                                    <i class="far fa-star text-warning" style="font-size: 1.2rem;"></i>
                                }
                            </div>
                        </div>

                        @if(!string.IsNullOrEmpty(Model.Feedback))
                        {
                            <div class="mb-3">
                                <p class="text-muted small mb-2">Your Feedback:</p>
                                <p class="mb-0">@Model.Feedback</p>
                            </div>
                        }

                        <p class="text-muted small mb-0"><i class="fas fa-check-circle"></i> Thank you for your feedback!</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .comments-section {
        border-radius: 12px;
        padding-right: 4px;
    }

    .activity-export-btn {
        border-radius: 10px;
        border-color: #d1d5db;
        color: #374151;
        font-weight: 600;
        padding: 0.38rem 0.72rem;
    }

    .activity-export-btn:hover {
        border-color: #4f46e5;
        color: #4f46e5;
        background: #eef2ff;
    }

    .ticket-line-graph {
        position: relative;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
        align-items: start;
    }

    .ticket-line-progress {
        position: absolute;
        top: 15px;
        left: 8%;
        right: 8%;
        height: 4px;
        border-radius: 999px;
        background: #e5e7eb;
        z-index: 1;
    }

    .ticket-line-progress::after {
        content: "";
        display: block;
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, #4f46e5, #06b6d4);
        width: 8%;
        transition: width 0.3s ease;
    }

    .ticket-line-progress.is-assigned::after {
        width: 36%;
    }

    .ticket-line-progress.is-updated::after {
        width: 68%;
    }

    .ticket-line-progress.is-closed::after {
        width: 100%;
    }

    .ticket-step {
        position: relative;
        z-index: 2;
        text-align: center;
    }

    .ticket-step-dot {
        width: 32px;
        height: 32px;
        margin: 0 auto 8px;
        border-radius: 999px;
        border: 2px solid #d1d5db;
        color: #9ca3af;
        background: #fff;
        display: grid;
        place-items: center;
        font-size: 0.75rem;
    }

    .ticket-step.done .ticket-step-dot {
        border-color: #4f46e5;
        color: #4f46e5;
        background: #e0e7ff;
    }

    .ticket-step-label {
        font-weight: 600;
    }

    .activity-timeline,
    .history-timeline {
        position: relative;
        padding-left: 20px;
    }

    .activity-timeline::before,
    .history-timeline::before {
        content: "";
        position: absolute;
        left: 31px;
        top: 6px;
        bottom: 14px;
        width: 3px;
        background: linear-gradient(180deg, #dbeafe 0%, #e5e7eb 100%);
        border-radius: 999px;
    }

    .activity-item,
    .history-item {
        position: relative;
        display: grid;
        grid-template-columns: 44px 1fr;
        gap: 16px;
        margin-bottom: 22px;
        align-items: start;
    }

    .activity-item:last-child,
    .history-item:last-child {
        margin-bottom: 8px;
    }

    .activity-marker {
        position: relative;
        z-index: 2;
        display: flex;
        justify-content: center;
    }

    .activity-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        background: #e0e7ff;
        color: #3730a3;
        font-weight: 700;
        font-size: 0.82rem;
        border: 2px solid #ffffff;
        box-shadow: 0 6px 14px rgba(17, 24, 39, 0.12);
    }

    .activity-avatar.system {
        background: #e0f2fe;
        color: #075985;
        font-size: 0.72rem;
    }

    .activity-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 18px 20px;
        box-shadow: 0 10px 24px rgba(17, 24, 39, 0.07);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .activity-item:hover .activity-card,
    .history-item:hover .activity-card {
        transform: translateY(-2px);
        box-shadow: 0 16px 30px rgba(17, 24, 39, 0.11);
    }

    .system-event .activity-card {
        background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
        border-color: #dbeafe;
    }

    .activity-name {
        color: #111827;
        font-weight: 700;
        font-size: 0.98rem;
    }

    .activity-time {
        color: #6b7280;
        font-size: 0.78rem;
        letter-spacing: 0.01em;
    }

    .activity-content {
        color: #111827;
        line-height: 1.65;
        margin-top: 8px;
        font-size: 0.95rem;
    }

    .activity-content ul,
    .activity-content ol {
        margin: 10px 0 0;
        padding-left: 18px;
    }

    .activity-content li {
        margin-bottom: 6px;
    }

    .activity-meta {
        display: grid;
        gap: 2px;
    }

    .ticket-tag {
        text-decoration: none;
        color: #4f46e5;
        font-size: 0.8rem;
        font-weight: 600;
        background: #eef2ff;
        border: 1px solid #c7d2fe;
        border-radius: 999px;
        padding: 4px 10px;
    }

    .ticket-tag:hover {
        background: #e0e7ff;
        color: #4338ca;
    }

    .history-timeline {
        margin-top: 4px;
    }

    @@media (max-width: 768px) {
        .ticket-line-graph {
            grid-template-columns: 1fr 1fr;
            row-gap: 18px;
        }

        .ticket-line-progress {
            display: none;
        }

        .activity-timeline,
        .history-timeline {
            padding-left: 0;
        }

        .activity-timeline::before,
        .history-timeline::before {
            left: 14px;
        }

        .activity-item,
        .history-item {
            grid-template-columns: 28px 1fr;
            gap: 10px;
            margin-bottom: 16px;
        }

        .activity-avatar {
            width: 26px;
            height: 26px;
            font-size: 0.72rem;
        }

        .activity-card {
            padding: 14px;
        }

        .activity-content {
            font-size: 0.92rem;
        }
    }

    .star-label {
        color: #ddd;
        transition: color 0.2s ease;
    }

    input[type="radio"]:checked ~ .star-label,
    .star-label:hover {
        color: #ffc107;
    }
</style>

@section Scripts {
    <script>
        // Star rating functionality
        const stars = document.querySelectorAll('.star-label');
        stars.forEach(star => {
            star.addEventListener('click', function() {
                const value = this.previousElementSibling.value;
                const allStars = document.querySelectorAll('.star-label');
                allStars.forEach(s => {
                    if(parseInt(s.previousElementSibling.value) <= value) {
                        s.style.color = '#ffc107';
                    } else {
                        s.style.color = '#ddd';
                    }
                });
            });
        });
    </script>
}
