@model TicketingSystem_DotNetMVC.Models.User
@{
    ViewData["Title"] = "User Profile";
}

<section class="profile-grid user-profile-theme">
    <div class="profile-card profile-identity">
        <div class="profile-avatar">@((Model.FullName ?? "U")[0])</div>
        <div>
            <h2 class="profile-title">@Model.FullName</h2>
            <p class="profile-subtitle">Customer Account</p>
            <span class="profile-pill">Role: @Model.Role</span>
        </div>
    </div>

    <div class="profile-card">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="profile-section-title mb-0">Update Account</h3>
            <button type="button" id="editProfileBtn" class="btn btn-outline-primary btn-sm">
                <i class="fas fa-pen-to-square me-1"></i>Edit Profile
            </button>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post" asp-action="UpdateProfile" asp-controller="Dashboard" class="profile-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" value="@Model.UserId" />

            <div class="mb-3">
                <label class="form-label">Full Name</label>
                <input type="text" class="form-control editable-field" name="fullName" value="@Model.FullName" required disabled />
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" class="form-control" value="@Model.Email" disabled />
            </div>

            <div class="mb-3">
                <label class="form-label">Current Password</label>
                <input type="password" class="form-control editable-field" name="currentPassword" placeholder="Required if changing password" disabled />
            </div>

            <div class="mb-3">
                <label class="form-label">New Password</label>
                <input type="password" class="form-control editable-field" name="newPassword" placeholder="Leave empty to keep current password" disabled />
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4">
                <small class="text-muted">Last login: @(Model.LastLoginDate?.ToString("dd MMM yyyy hh:mm tt") ?? "Never")</small>
                <button type="submit" id="saveProfileBtn" class="btn btn-primary px-4" disabled>Save</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <script>
        (function profileEditToggle() {
            const editBtn = document.getElementById('editProfileBtn');
            const saveBtn = document.getElementById('saveProfileBtn');
            const fields = document.querySelectorAll('.editable-field');

            if (!editBtn || !saveBtn || !fields.length) {
                return;
            }

            editBtn.addEventListener('click', function () {
                fields.forEach(field => {
                    field.removeAttribute('disabled');
                });
                saveBtn.removeAttribute('disabled');
                editBtn.setAttribute('disabled', 'disabled');
                fields[0].focus();
            });
        })();
    </script>
}