@model TicketingSystem_DotNetMVC.Models.Ticket
@{
    ViewData["Title"] = "Create New Ticket - TicketSphere";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="page-title"><i class="fas fa-plus-circle text-primary me-2"></i>Create New Ticket</h1>
            <p class="text-muted">Fill in the details below to create a service request</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-9 col-xl-8">
            <div class="card mb-4">
                <div class="card-body p-5">
                    <form method="post" asp-action="CreateTicket" asp-controller="Dashboard">
                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-bold">Ticket Title</label>
                            <input asp-for="Title" type="text" class="form-control form-control-lg" placeholder="Brief title of the issue" required>
                            <span asp-validation-for="Title" class="text-danger small"></span>
                            <small class="text-muted d-block mt-2">Max 200 characters - Be clear and specific</small>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold">Detailed Description</label>
                            <textarea asp-for="Description" class="form-control form-control-lg" rows="6" 
                                      placeholder="Provide detailed information about your issue..." required></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                            <small class="text-muted d-block mt-2">Include as much detail as possible</small>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Priority" class="form-label fw-bold">Priority Level</label>
                            <select asp-for="Priority" class="form-select form-select-lg" required>
                                <option value="">-- Select Priority --</option>
                                <option value="Low">Low - Can wait</option>
                                <option value="Medium">Medium - Normal</option>
                                <option value="High">High - Urgent</option>
                            </select>
                            <span asp-validation-for="Priority" class="text-danger small"></span>
                            <small class="text-muted d-block mt-2">Helps us prioritize your request</small>
                        </div>

                        <div class="alert alert-info alert-sm mb-4" role="alert">
                            <i class="fas fa-info-circle"></i> 
                            <strong>Note:</strong> Your ticket will be created with Open status. 
                            An agent will be assigned shortly.
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="fas fa-check-circle"></i> Create Ticket
                            </button>
                            <a href="@Url.Action("Dashboard", "Dashboard")" class="btn btn-secondary px-4">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card border-0" role="alert" style="background:#fff7ed;border:1px solid #fed7aa !important;">
                <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="fas fa-lightbulb"></i> Tips for Creating Effective Tickets:</h6>
                <ul class="mb-0 ps-3">
                    <li><strong>Be Specific:</strong> Clearly describe what's happening</li>
                    <li><strong>Include Details:</strong> When did the issue start? How often does it occur?</li>
                    <li><strong>Set Right Priority:</strong> High priority tickets get faster response</li>
                    <li><strong>Provide Context:</strong> Any error messages or screenshots help</li>
                </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
