@{
    ViewData["Title"] = "Reports";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="h3 fw-bold">📈 System Reports</h1>
            <p class="text-muted">Analytics and performance metrics for your ticketing system</p>
        </div>
    </div>

    <!-- Key Metrics Row -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="me-3">
                            <i class="fa-solid fa-ticket" style="font-size: 2rem; color: #0d6efd;"></i>
                        </div>
                        <div>
                            <h6 class="card-title text-muted mb-0">Total Tickets</h6>
                            <h3 class="fw-bold mb-0">156</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="me-3">
                            <i class="fa-solid fa-hourglass-start" style="font-size: 2rem; color: #d97706;"></i>
                        </div>
                        <div>
                            <h6 class="card-title text-muted mb-0">Avg. Resolution Time</h6>
                            <h3 class="fw-bold mb-0">2.3 days</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="me-3">
                            <i class="fa-solid fa-users" style="font-size: 2rem; color: #16a34a;"></i>
                        </div>
                        <div>
                            <h6 class="card-title text-muted mb-0">Active Users</h6>
                            <h3 class="fw-bold mb-0">48</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="me-3">
                            <i class="fa-solid fa-check-circle" style="font-size: 2rem; color: #0ea5e9;"></i>
                        </div>
                        <div>
                            <h6 class="card-title text-muted mb-0">Resolution Rate</h6>
                            <h3 class="fw-bold mb-0">87.5%</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="row mb-4">
        <div class="col-lg-6 mb-3">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light border-bottom">
                    <h5 class="mb-0">Ticket Status Distribution</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Status</th>
                                    <th>Count</th>
                                    <th>Percentage</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><span class="badge status-open">Open</span></td>
                                    <td>35</td>
                                    <td>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar" style="width: 22%; background: #0d6efd;"></div>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td><span class="badge status-progress">In Progress</span></td>
                                    <td>42</td>
                                    <td>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar" style="width: 27%; background: #d97706;"></div>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td><span class="badge status-closed">Closed</span></td>
                                    <td>79</td>
                                    <td>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar" style="width: 51%; background: #16a34a;"></div>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 mb-3">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light border-bottom">
                    <h5 class="mb-0">Agent Performance</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Agent Name</th>
                                    <th>Resolved</th>
                                    <th>Avg. Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Agent Alex</td>
                                    <td><span class="badge bg-success">28</span></td>
                                    <td>2.1 days</td>
                                </tr>
                                <tr>
                                    <td>Agent Sam</td>
                                    <td><span class="badge bg-success">26</span></td>
                                    <td>2.4 days</td>
                                </tr>
                                <tr>
                                    <td>Agent Meera</td>
                                    <td><span class="badge bg-success">25</span></td>
                                    <td>2.6 days</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Priority Distribution -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light border-bottom">
                    <h5 class="mb-0">Tickets by Priority</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <div class="p-3 border rounded text-center">
                                <i class="fa-solid fa-exclamation-circle" style="font-size: 2rem; color: #dc2626;"></i>
                                <h6 class="mt-2 mb-0">High Priority</h6>
                                <h3 class="fw-bold" style="color: #dc2626;">23</h3>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="p-3 border rounded text-center">
                                <i class="fa-solid fa-circle-exclamation" style="font-size: 2rem; color: #f59e0b;"></i>
                                <h6 class="mt-2 mb-0">Medium Priority</h6>
                                <h3 class="fw-bold" style="color: #f59e0b;">78</h3>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="p-3 border rounded text-center">
                                <i class="fa-solid fa-circle-info" style="font-size: 2rem; color: #3b82f6;"></i>
                                <h6 class="mt-2 mb-0">Low Priority</h6>
                                <h3 class="fw-bold" style="color: #3b82f6;">55</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .badge {
        padding: 0.35rem 0.65rem;
        font-size: 0.85rem;
    }

    .status-open {
        background: #e8f1ff;
        color: #0d6efd;
    }

    .status-progress {
        background: #fff2df;
        color: #d97706;
    }

    .status-closed {
        background: #e8f8ee;
        color: #16a34a;
    }
</style>
