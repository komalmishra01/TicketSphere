@model IEnumerable<TicketingSystem_DotNetMVC.Models.Ticket>
@{
    ViewData["Title"] = "Reports";
    var totalTickets = Model.Count();
    var openTickets = Model.Count(t => t.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.Open);
    var inProgressTickets = Model.Count(t => t.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.InProgress);
    var closedTickets = Model.Count(t => t.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.Closed);
    var resolutionRate = totalTickets > 0 ? (double)closedTickets / totalTickets * 100 : 0;
}

<div class="container-fluid">
    <div class="mb-4">
        <h1 class="page-title"><i class="fas fa-chart-line text-primary me-2"></i>System Analytics</h1>
        <p class="page-subtitle">Real-time performance metrics and ticket statistics across the platform.</p>
    </div>

    <!-- Key Metrics Row -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-3">
                            <i class="fas fa-ticket-alt fa-2x"></i>
                        </div>
                        <div class="text-end">
                            <div class="text-muted small fw-bold text-uppercase">Total Tickets</div>
                            <div class="h2 mb-0 mt-1">@totalTickets</div>
                        </div>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: 100%"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="bg-warning bg-opacity-10 text-warning p-3 rounded-3">
                            <i class="fas fa-clock fa-2x"></i>
                        </div>
                        <div class="text-end">
                            <div class="text-muted small fw-bold text-uppercase">Open Tickets</div>
                            <div class="h2 mb-0 mt-1">@openTickets</div>
                        </div>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-warning" role="progressbar" style="width: @(totalTickets > 0 ? (openTickets * 100 / totalTickets) : 0)%"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="bg-info bg-opacity-10 text-info p-3 rounded-3">
                            <i class="fas fa-spinner fa-2x"></i>
                        </div>
                        <div class="text-end">
                            <div class="text-muted small fw-bold text-uppercase">In Progress</div>
                            <div class="h2 mb-0 mt-1">@inProgressTickets</div>
                        </div>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-info" role="progressbar" style="width: @(totalTickets > 0 ? (inProgressTickets * 100 / totalTickets) : 0)%"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="bg-success bg-opacity-10 text-success p-3 rounded-3">
                            <i class="fas fa-check-double fa-2x"></i>
                        </div>
                        <div class="text-end">
                            <div class="text-muted small fw-bold text-uppercase">Resolution Rate</div>
                            <div class="h2 mb-0 mt-1">@resolutionRate.ToString("0.0")%</div>
                        </div>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: @resolutionRate%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold">Ticket Distribution by Status</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4">Status</th>
                                    <th>Total Count</th>
                                    <th>Percentage</th>
                                    <th class="pe-4" style="width: 200px;">Progress</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="ps-4"><span class="badge bg-warning bg-opacity-10 text-warning px-3">Open</span></td>
                                    <td>@openTickets</td>
                                    <td>@(totalTickets > 0 ? (openTickets * 100 / totalTickets) : 0)%</td>
                                    <td class="pe-4">
                                        <div class="progress" style="height: 8px;">
                                            <div class="progress-bar bg-warning" style="width: @(totalTickets > 0 ? (openTickets * 100 / totalTickets) : 0)%"></div>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="ps-4"><span class="badge bg-info bg-opacity-10 text-info px-3">In Progress</span></td>
                                    <td>@inProgressTickets</td>
                                    <td>@(totalTickets > 0 ? (inProgressTickets * 100 / totalTickets) : 0)%</td>
                                    <td class="pe-4">
                                        <div class="progress" style="height: 8px;">
                                            <div class="progress-bar bg-info" style="width: @(totalTickets > 0 ? (inProgressTickets * 100 / totalTickets) : 0)%"></div>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="ps-4"><span class="badge bg-success bg-opacity-10 text-success px-3">Closed</span></td>
                                    <td>@closedTickets</td>
                                    <td>@(totalTickets > 0 ? (closedTickets * 100 / totalTickets) : 0)%</td>
                                    <td class="pe-4">
                                        <div class="progress" style="height: 8px;">
                                            <div class="progress-bar bg-success" style="width: @(totalTickets > 0 ? (closedTickets * 100 / totalTickets) : 0)%"></div>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold">System Health</h5>
                </div>
                <div class="card-body text-center p-4">
                    <div class="mb-4">
                        <div class="h1 fw-bold text-primary">@totalTickets</div>
                        <div class="text-muted small">Total Requests Processed</div>
                    </div>
                    <div class="p-3 bg-light rounded-3 mb-4 text-start">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="small">System Uptime</span>
                            <span class="small fw-bold">99.9%</span>
                        </div>
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar bg-success" style="width: 99.9%"></div>
                        </div>
                    </div>
                    <button class="btn btn-outline-primary w-100 mb-2">
                        <i class="fas fa-download me-2"></i>Download Full Report
                    </button>
                    <button class="btn btn-primary w-100">
                        <i class="fas fa-print me-2"></i>Print Analytics
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>