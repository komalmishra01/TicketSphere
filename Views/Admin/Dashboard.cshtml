@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="mb-4">
    <h3 class="mb-1 page-title">Admin Dashboard</h3>
    <p class="text-secondary mb-0">Overview of tickets, users, and agents.</p>
</div>

<div class="row g-3">
    <div class="col-sm-6 col-xl">
        <div class="card summary-card"><div class="card-body p-0"><div class="small text-secondary">Total Tickets</div><h4 class="mb-0">124</h4></div></div>
    </div>
    <div class="col-sm-6 col-xl">
        <div class="card summary-card"><div class="card-body p-0"><div class="small text-secondary">Open</div><h4 class="mb-0">35</h4></div></div>
    </div>
    <div class="col-sm-6 col-xl">
        <div class="card summary-card"><div class="card-body p-0"><div class="small text-secondary">Closed</div><h4 class="mb-0">89</h4></div></div>
    </div>
    <div class="col-sm-6 col-xl">
        <div class="card summary-card"><div class="card-body p-0"><div class="small text-secondary">Users</div><h4 class="mb-0">48</h4></div></div>
    </div>
    <div class="col-sm-6 col-xl">
        <div class="card summary-card"><div class="card-body p-0"><div class="small text-secondary">Agents</div><h4 class="mb-0">9</h4></div></div>
    </div>
</div>
