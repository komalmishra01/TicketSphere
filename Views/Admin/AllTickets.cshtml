@{
    ViewData["Title"] = "All Tickets";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0 page-title">All Tickets</h3>
    <a href="/Admin/Dashboard" class="btn btn-outline-secondary btn-sm">Back</a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-6">
                <label class="form-label">Search Tickets</label>
                <input class="form-control" placeholder="Search by ID, title, or user" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select class="form-select">
                    <option>All</option>
                    <option>Open</option>
                    <option>In Progress</option>
                    <option>Closed</option>
                </select>
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary w-100"><i class="fas fa-filter me-1"></i>Apply Filters</button>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-table-list text-primary me-2"></i>Ticket Management</h5>
        <span class="badge bg-secondary">2 Tickets</span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th>Ticket ID</th>
                    <th>Title</th>
                    <th>User</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Assign Agent</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>#AD-101</td>
                    <td>Printer issue</td>
                    <td>Aryan</td>
                    <td><span class="badge bg-warning text-dark">Medium</span></td>
                    <td><span class="badge status-open">Open</span></td>
                    <td>
                        <select class="form-select form-select-sm">
                            <option>Select Agent</option>
                            <option>Agent Alex</option>
                            <option>Agent Sam</option>
                        </select>
                    </td>
                </tr>
                <tr>
                    <td>#AD-102</td>
                    <td>Billing portal error</td>
                    <td>Sneha</td>
                    <td><span class="badge bg-danger">High</span></td>
                    <td><span class="badge status-progress">In Progress</span></td>
                    <td>
                        <select class="form-select form-select-sm">
                            <option>Select Agent</option>
                            <option selected>Agent Sam</option>
                            <option>Agent Alex</option>
                        </select>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
