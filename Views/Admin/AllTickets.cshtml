@model IEnumerable<TicketingSystem_DotNetMVC.Models.Ticket>
@{
    ViewData["Title"] = "All Tickets";
    var agents = ViewBag.Agents as List<TicketingSystem_DotNetMVC.Models.User> ?? new List<TicketingSystem_DotNetMVC.Models.User>();
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="page-title"><i class="fas fa-list-check text-primary me-2"></i>Global Ticket Management</h1>
            <p class="page-subtitle">View and assign tickets to support agents.</p>
        </div>
        <a href="/Admin/Dashboard" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to Dashboard
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold">Recent Tickets</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Title</th>
                            <th>User</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Assign To</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ticket in Model)
                        {
                            <tr>
                                <td class="ps-4"><strong>#@ticket.TicketId</strong></td>
                                <td>@ticket.Title</td>
                                <td>@ticket.User?.FullName</td>
                                <td>
                                    @{
                                        var pClass = ticket.Priority == TicketingSystem_DotNetMVC.Models.TicketPriority.High ? "danger" :
                                                    ticket.Priority == TicketingSystem_DotNetMVC.Models.TicketPriority.Medium ? "warning" : "info";
                                    }
                                    <span class="badge bg-@pClass bg-opacity-10 text-@pClass">@ticket.Priority</span>
                                </td>
                                <td>
                                    @{
                                        var sClass = ticket.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.Open ? "primary" :
                                                    ticket.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.InProgress ? "warning" : "success";
                                    }
                                    <span class="badge bg-@sClass bg-opacity-10 text-@sClass">@ticket.Status</span>
                                </td>
                                <td>
                                    <form asp-action="AssignTicket" method="post" class="d-flex gap-2 align-items-center">
                                        <input type="hidden" name="ticketId" value="@ticket.TicketId" />
                                        <select name="agentId" class="form-select form-select-sm" style="min-width: 150px;">
                                            <option value="">-- Unassigned --</option>
                                            @foreach (var agent in agents)
                                            {
                                                <option value="@agent.UserId" selected="@(ticket.AssignedAgentId == agent.UserId)">
                                                    @agent.FullName
                                                </option>
                                            }
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-primary">Assign</button>
                                    </form>
                                </td>
                                <td class="text-end pe-4">
                                    <a href="/Tickets/Details/@ticket.TicketId" class="btn btn-sm btn-outline-primary rounded-circle p-2">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>