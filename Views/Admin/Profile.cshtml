@model TicketingSystem_DotNetMVC.Models.User
@{
    ViewData["Title"] = "Admin Profile";
}

<section class="profile-grid admin-profile-theme">
    <div class="profile-card profile-identity">
        <div class="profile-avatar">@((Model.FullName ?? "A")[0])</div>
        <div>
            <h2 class="profile-title">@Model.FullName</h2>
            <p class="profile-subtitle">System Administrator</p>
            <span class="profile-pill">Full Access</span>
        </div>
    </div>

    <div class="profile-card">
        <h3 class="profile-section-title">Administrative Account</h3>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post" asp-action="UpdateProfile" asp-controller="Admin" class="profile-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" value="@Model.UserId" />

            <div class="mb-3">
                <label class="form-label">Admin Name</label>
                <input type="text" class="form-control" name="fullName" value="@Model.FullName" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Admin Email</label>
                <input type="email" class="form-control" value="@Model.Email" disabled />
            </div>

            <div class="mb-3">
                <label class="form-label">Current Password</label>
                <input type="password" class="form-control" name="currentPassword" />
            </div>

            <div class="mb-3">
                <label class="form-label">New Password</label>
                <input type="password" class="form-control" name="newPassword" />
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4">
                <small class="text-muted">Last login: @(Model.LastLoginDate?.ToString("dd MMM yyyy hh:mm tt") ?? "Never")</small>
                <button type="submit" class="btn btn-dark px-4">Apply Changes</button>
            </div>
        </form>
    </div>
</section>