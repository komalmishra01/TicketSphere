@{
    ViewData["Title"] = "Send System Notification";
}

<div class="container-fluid">
    <div class="mb-4">
        <h1 class="page-title"><i class="fas fa-bullhorn text-primary me-2"></i>Send Notification</h1>
        <p class="page-subtitle">Broadcast a message to users and agents via Web and Email.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5">
                    <form asp-action="SendNotification" method="post">
                        <div class="mb-4">
                            <label class="form-label fw-bold">Target Audience</label>
                            <select name="targetRole" class="form-select form-select-lg" required>
                                <option value="All">All Users & Agents</option>
                                <option value="User">Users Only</option>
                                <option value="Agent">Agents Only</option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Email Subject</label>
                            <input type="text" name="subject" class="form-control form-control-lg" placeholder="e.g. System Maintenance Update" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Message Content</label>
                            <textarea name="message" class="form-control form-control-lg" rows="6" placeholder="Type your broadcast message here..." required></textarea>
                            <small class="text-muted mt-2 d-block">This message will be sent to the target audience's registered email and shown in their web dashboard.</small>
                        </div>

                        <div class="alert alert-warning border-0 shadow-sm mb-4">
                            <div class="d-flex">
                                <i class="fas fa-exclamation-triangle mt-1 me-3"></i>
                                <div>
                                    <strong>Important:</strong> This action cannot be undone. Please verify the content before sending.
                                </div>
                            </div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg px-5 py-3">
                                <i class="fas fa-paper-plane me-2"></i> Broadcast Notification
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>