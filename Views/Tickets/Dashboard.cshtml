@model IEnumerable<TicketingSystem_DotNetMVC.Models.Ticket>
@{
    ViewData["Title"] = "User Dashboard";
}

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card card-stats bg-primary text-white p-3 text-center">
            <h3>@ViewBag.TotalTickets</h3>
            <p>Total Tickets</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card card-stats bg-info text-white p-3 text-center">
            <h3>@ViewBag.OpenTickets</h3>
            <p>Open</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card card-stats bg-warning text-dark p-3 text-center">
            <h3>@ViewBag.InProgressTickets</h3>
            <p>In Progress</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card card-stats bg-success text-white p-3 text-center">
            <h3>@ViewBag.ClosedTickets</h3>
            <p>Closed</p>
        </div>
    </div>
</div>

<div class="card mt-4 border-0 shadow-sm">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold"><i class="fas fa-history me-2"></i>Recent Tickets</h5>
        <a asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-3">ID</th>
                        <th>Title</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th class="text-end pe-3">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-bold">#@item.Id</td>
                            <td>@item.Title</td>
                            <td>
                                <span class="badge badge-@item.Priority.ToString().ToLower()">@item.Priority</span>
                            </td>
                            <td>
                                <span class="badge badge-@item.Status.ToString().ToLower()">@item.Status</span>
                            </td>
                            <td>@item.CreatedDate.ToString("MMM dd, yyyy HH:mm")</td>
                            <td class="text-end pe-3">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light text-primary">
                                    <i class="fas fa-eye"></i> View
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4">No recent tickets found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
