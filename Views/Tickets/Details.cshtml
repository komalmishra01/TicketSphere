@model TicketingSystem_DotNetMVC.Models.Ticket
@{
    ViewData["Title"] = "Ticket Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Ticket #@Model.Id: @Model.Title</h4>
        <span class="text-muted small">Created on @Model.CreatedDate.ToString("MMM dd, yyyy HH:mm")</span>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-left me-2"></i>Back to List</a>
        <button class="btn btn-primary btn-sm"><i class="fas fa-download me-2"></i>Export PDF</button>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <!-- Ticket Information -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3 border-bottom">
                <h5 class="mb-0 fw-bold">Issue Description</h5>
            </div>
            <div class="card-body">
                <p class="card-text fs-5">@Model.Description</p>
                
                @if (!string.IsNullOrEmpty(Model.AttachmentPath))
                {
                    <div class="mt-4 p-3 bg-light rounded border d-flex align-items-center">
                        <i class="fas fa-paperclip me-3 text-primary fs-4"></i>
                        <div>
                            <p class="mb-0 fw-bold">Attachment.jpg</p>
                            <a href="#" class="text-decoration-none small">Download Attachment</a>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Comments Section -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="fas fa-comments me-2"></i>Discussion</h5>
                <span class="badge bg-light text-dark">@Model.Comments.Count Comments</span>
            </div>
            <div class="card-body">
                <div class="chat-container mb-4">
                    @foreach (var comment in Model.Comments.OrderBy(c => c.CreatedDate))
                    {
                        <div class="d-flex mb-4 @(comment.CreatedBy == "Agent Smith" ? "justify-content-start" : "justify-content-end")">
                            <div class="max-width-75 p-3 rounded-3 @(comment.CreatedBy == "Agent Smith" ? "bg-light text-dark border" : "bg-primary text-white shadow-sm")">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fw-bold small">@comment.CreatedBy</span>
                                    <span class="ms-3 small opacity-75">@comment.CreatedDate.ToString("HH:mm")</span>
                                </div>
                                <p class="mb-0">@comment.Message</p>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-4 border-top pt-4">
                    <label class="form-label fw-bold">Add a Reply</label>
                    <div class="input-group">
                        <textarea class="form-control bg-light border-0" rows="2" placeholder="Write your message here..."></textarea>
                        <button class="btn btn-primary px-4"><i class="fas fa-paper-plane"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <!-- Ticket Metadata -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3 border-bottom">
                <h5 class="mb-0 fw-bold">Properties</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="text-muted small d-block">Status</label>
                    <span class="badge badge-@Model.Status.ToString().ToLower() px-3 py-2 fs-6 mt-1">@Model.Status</span>
                </div>
                <div class="mb-3">
                    <label class="text-muted small d-block">Priority</label>
                    <span class="badge badge-@Model.Priority.ToString().ToLower() px-3 py-2 fs-6 mt-1">@Model.Priority</span>
                </div>
                <div class="mb-3">
                    <label class="text-muted small d-block">Assigned To</label>
                    <div class="d-flex align-items-center mt-1">
                        <img src="https://ui-avatars.com/api/?name=Agent+Smith&background=f1c40f&color=fff" class="rounded-circle me-2" width="30" height="30">
                        <span class="fw-bold">Agent Smith</span>
                    </div>
                </div>
                <hr>
                <div class="mb-3">
                    <label class="text-muted small d-block">Last Updated</label>
                    <span class="fw-bold">@Model.UpdatedDate?.ToString("MMM dd, yyyy HH:mm") ?? "N/A"</span>
                </div>
            </div>
        </div>

        <!-- Activity Timeline -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 border-bottom">
                <h5 class="mb-0 fw-bold">Activity Timeline</h5>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item border-0 py-3 ps-4 position-relative">
                        <div class="position-absolute start-0 top-0 bottom-0 border-start border-primary border-3 ms-2"></div>
                        <i class="fas fa-check-circle position-absolute start-0 bg-white text-primary ms-1 mt-3" style="z-index:1;"></i>
                        <p class="mb-0 small fw-bold">Ticket Created</p>
                        <p class="mb-0 text-muted smaller">@Model.CreatedDate.ToString("MMM dd, HH:mm")</p>
                    </li>
                    <li class="list-group-item border-0 py-3 ps-4 position-relative">
                        <div class="position-absolute start-0 top-0 bottom-0 border-start border-warning border-3 ms-2"></div>
                        <i class="fas fa-user-check position-absolute start-0 bg-white text-warning ms-1 mt-3" style="z-index:1;"></i>
                        <p class="mb-0 small fw-bold">Agent Assigned</p>
                        <p class="mb-0 text-muted smaller">@Model.CreatedDate.AddHours(1).ToString("MMM dd, HH:mm")</p>
                    </li>
                </ul>
            </div>
        </div>

        @if (Model.Status == TicketStatus.Closed)
        {
            <div class="card border-0 shadow-sm mt-4 bg-light">
                <div class="card-body text-center">
                    <h6 class="fw-bold">Rate Service</h6>
                    <div class="text-warning mb-2">
                        <i class="far fa-star fs-4"></i>
                        <i class="far fa-star fs-4"></i>
                        <i class="far fa-star fs-4"></i>
                        <i class="far fa-star fs-4"></i>
                        <i class="far fa-star fs-4"></i>
                    </div>
                    <button class="btn btn-sm btn-primary">Submit Rating</button>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .max-width-75 { max-width: 75%; }
    .smaller { font-size: 0.75rem; }
</style>
