@model TicketingSystem_DotNetMVC.Models.Ticket
@{
    ViewData["Title"] = "Ticket Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Ticket #@Model.TicketId: @Model.Title</h4>
        <span class="text-muted small">Created on @Model.CreatedDate.ToString("MMM dd, yyyy HH:mm")</span>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-left me-2"></i>Back to List</a>
        <button class="btn btn-primary btn-sm"><i class="fas fa-download me-2"></i>Export PDF</button>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <!-- Ticket Information -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3 border-bottom">
                <h5 class="mb-0 fw-bold">Issue Description</h5>
            </div>
            <div class="card-body">
                <p class="card-text fs-5">@Model.Description</p>
                
                @if (!string.IsNullOrEmpty(Model.Attachments))
                {
                    <div class="mt-4 p-3 bg-light rounded border">
                        <h6 class="fw-bold mb-3 small text-uppercase text-muted"><i class="fas fa-paperclip me-2"></i>Attached Screenshot</h6>
                        <a href="@Model.Attachments" target="_blank">
                            <img src="@Model.Attachments" class="img-fluid rounded border shadow-sm" style="max-height: 400px;" alt="Issue Screenshot" />
                        </a>
                        <div class="mt-2">
                            <a href="@Model.Attachments" download class="text-decoration-none small"><i class="fas fa-download me-1"></i>Download Image</a>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Comments Section -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="fas fa-comments me-2"></i>Discussion</h5>
                <span class="badge bg-light text-dark">@Model.Comments.Count Comments</span>
            </div>
            <div class="card-body">
                <div class="chat-container mb-4">
                    @foreach (var comment in Model.Comments.OrderBy(c => c.CreatedDate))
                    {
                        var isAgent = comment.User.Role == "Agent" || comment.User.Role == "Admin";
                        <div class="d-flex mb-4 @(isAgent ? "justify-content-start" : "justify-content-end")">
                            <div class="max-width-75 p-3 rounded-3 @(isAgent ? "bg-light text-dark border" : "bg-primary text-white shadow-sm")">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fw-bold small">@comment.User.FullName</span>
                                    <span class="ms-3 small opacity-75">@comment.CreatedDate.ToString("HH:mm")</span>
                                </div>
                                <p class="mb-0">@comment.Message</p>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-4 border-top pt-4">
                    <form asp-action="AddComment" asp-controller="Tickets" method="post">
                        <input type="hidden" name="ticketId" value="@Model.TicketId" />
                        <label class="form-label fw-bold">Add a Reply</label>
                        <div class="input-group">
                            <textarea name="message" class="form-control bg-light border-0" rows="2" placeholder="Write your message here..." required></textarea>
                            <button type="submit" class="btn btn-primary px-4"><i class="fas fa-paper-plane"></i></button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <!-- Ticket Metadata -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3 border-bottom">
                <h5 class="mb-0 fw-bold">Properties</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="text-muted small d-block">Status</label>
                    @{
                        var sBadge = Model.Status == TicketStatus.Open ? "primary" :
                                    Model.Status == TicketStatus.InProgress ? "warning text-dark" : "success";
                    }
                    <span class="badge bg-@sBadge px-3 py-2 fs-6 mt-1 shadow-sm">@Model.Status</span>
                </div>
                <div class="mb-3">
                    <label class="text-muted small d-block">Priority</label>
                    @{
                        var pBadge = Model.Priority == TicketPriority.High ? "danger" :
                                    Model.Priority == TicketPriority.Medium ? "warning text-dark" : "info";
                    }
                    <span class="badge bg-@pBadge px-3 py-2 fs-6 mt-1 shadow-sm">@Model.Priority</span>
                </div>
                <div class="mb-3">
                    <label class="text-muted small d-block">Assigned To</label>
                    <div class="d-flex align-items-center mt-1">
                        @if (Model.AssignedAgent != null)
                        {
                            <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(Model.AssignedAgent.FullName))&background=0d6efd&color=fff" class="rounded-circle me-2 shadow-sm" width="32" height="32">
                            <span class="fw-bold text-dark">@Model.AssignedAgent.FullName</span>
                        }
                        else
                        {
                            <div class="bg-secondary bg-opacity-10 text-secondary rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                <i class="fas fa-user-slash small"></i>
                            </div>
                            <span class="text-muted italic small">Unassigned</span>
                        }
                    </div>
                </div>
                <hr class="my-3">
                <div class="mb-3">
                    <label class="text-muted small d-block">Last Updated</label>
                    <span class="fw-bold text-dark">@(Model.UpdatedDate?.ToString("MMM dd, yyyy HH:mm") ?? "N/A")</span>
                </div>
            </div>
        </div>

        <!-- Activity Timeline -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 border-bottom">
                <h5 class="mb-0 fw-bold">Activity Timeline</h5>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item border-0 py-3 ps-4 position-relative">
                        <div class="position-absolute start-0 top-0 bottom-0 border-start border-primary border-3 ms-2"></div>
                        <i class="fas fa-check-circle position-absolute start-0 bg-white text-primary ms-1 mt-3" style="z-index:1;"></i>
                        <p class="mb-0 small fw-bold">Ticket Created</p>
                        <p class="mb-0 text-muted smaller">@Model.CreatedDate.ToString("MMM dd, HH:mm")</p>
                    </li>
                    @if (Model.AssignedAgent != null)
                    {
                        <li class="list-group-item border-0 py-3 ps-4 position-relative">
                            <div class="position-absolute start-0 top-0 bottom-0 border-start border-warning border-3 ms-2"></div>
                            <i class="fas fa-user-check position-absolute start-0 bg-white text-warning ms-1 mt-3" style="z-index:1;"></i>
                            <p class="mb-0 small fw-bold">Agent Assigned</p>
                            <p class="mb-0 text-muted smaller">Assigned to @Model.AssignedAgent.FullName</p>
                        </li>
                    }
                    @if (Model.Status == TicketStatus.Closed)
                    {
                        <li class="list-group-item border-0 py-3 ps-4 position-relative">
                            <div class="position-absolute start-0 top-0 bottom-0 border-start border-success border-3 ms-2"></div>
                            <i class="fas fa-flag-checkered position-absolute start-0 bg-white text-success ms-1 mt-3" style="z-index:1;"></i>
                            <p class="mb-0 small fw-bold">Ticket Closed</p>
                            <p class="mb-0 text-muted smaller">@Model.ClosedDate?.ToString("MMM dd, HH:mm")</p>
                        </li>
                    }
                </ul>
            </div>
        </div>

        @if (Model.Status == TicketStatus.Closed)
        {
            <div class="card border-0 shadow-sm mt-4 bg-light">
                <div class="card-body text-center">
                    <h6 class="fw-bold">Rate Service</h6>
                    <div class="text-warning mb-2">
                        <i class="far fa-star fs-4"></i>
                        <i class="far fa-star fs-4"></i>
                        <i class="far fa-star fs-4"></i>
                        <i class="far fa-star fs-4"></i>
                        <i class="far fa-star fs-4"></i>
                    </div>
                    <button class="btn btn-sm btn-primary">Submit Rating</button>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .max-width-75 { max-width: 75%; }
    .smaller { font-size: 0.75rem; }
</style>
