@model IEnumerable<TicketingSystem_DotNetMVC.Models.Ticket>
@{
    ViewData["Title"] = "My Tickets";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">My Tickets</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>New Ticket</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-light border-0"><i class="fas fa-search"></i></span>
                    <input type="text" id="ticketSearch" class="form-control bg-light border-0" placeholder="Search by ticket title or ID...">
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select bg-light border-0" id="statusFilter">
                    <option value="">All Status</option>
                    <option value="Open">Open</option>
                    <option value="InProgress">In Progress</option>
                    <option value="Closed">Closed</option>
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select bg-light border-0" id="priorityFilter">
                    <option value="">All Priorities</option>
                    <option value="High">High</option>
                    <option value="Medium">Medium</option>
                    <option value="Low">Low</option>
                </select>
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="ticketsTable">
                <thead class="bg-light text-muted fw-normal">
                    <tr>
                        <th class="ps-3 py-3">ID</th>
                        <th class="py-3">Title</th>
                        <th class="py-3">Priority</th>
                        <th class="py-3">Status</th>
                        <th class="py-3">Date Created</th>
                        <th class="text-end pe-3 py-3">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="ticket-row" data-status="@item.Status" data-priority="@item.Priority">
                            <td class="ps-3 fw-bold text-muted">#@item.Id</td>
                            <td class="fw-semibold">@item.Title</td>
                            <td>
                                <span class="badge badge-@item.Priority.ToString().ToLower()">@item.Priority</span>
                            </td>
                            <td>
                                <span class="badge badge-@item.Status.ToString().ToLower()">@item.Status</span>
                            </td>
                            <td class="text-muted">@item.CreatedDate.ToString("MMM dd, yyyy")</td>
                            <td class="text-end pe-3">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light border">
                                    <i class="fas fa-info-circle me-1"></i>Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#ticketSearch").on("keyup", function () {
                var value = $(this).val().toLowerCase();
                $("#ticketsTable tbody tr").filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });

            $("#statusFilter, #priorityFilter").on("change", function() {
                var status = $("#statusFilter").val();
                var priority = $("#priorityFilter").val();
                
                $(".ticket-row").each(function() {
                    var showStatus = !status || $(this).data("status") === status;
                    var showPriority = !priority || $(this).data("priority") === priority;
                    $(this).toggle(showStatus && showPriority);
                });
            });
        });
    </script>
}
