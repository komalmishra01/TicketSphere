@model IEnumerable<TicketingSystem_DotNetMVC.Models.Ticket>
@{
    ViewData["Title"] = "Agent Dashboard";
}

<div class="mb-4">
    <h3 class="mb-1 page-title">Agent Dashboard</h3>
    <p class="text-secondary mb-0">Track assigned tickets and progress.</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card summary-card bg-primary text-white"><div class="card-body p-0"><div class="small opacity-75">Assigned Tickets</div><h4 class="mb-0">@ViewBag.AssignedTickets</h4></div></div>
    </div>
    <div class="col-md-3">
        <div class="card summary-card bg-warning text-dark"><div class="card-body p-0"><div class="small opacity-75">Unassigned Open</div><h4 class="mb-0">@ViewBag.UnassignedTickets</h4></div></div>
    </div>
    <div class="col-md-3">
        <div class="card summary-card bg-success text-white"><div class="card-body p-0"><div class="small opacity-75">Completed</div><h4 class="mb-0">@ViewBag.CompletedTickets</h4></div></div>
    </div>
    <div class="col-md-3">
        <div class="card summary-card bg-info text-white"><div class="card-body p-0"><div class="small opacity-75">Pending My Task</div><h4 class="mb-0">@ViewBag.PendingTickets</h4></div></div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 border-0">
        <h5 class="mb-0 fw-bold">Recent Tickets (Assigned & Unassigned)</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Ticket ID</th>
                        <th>Subject</th>
                        <th>User</th>
                        <th>Status</th>
                        <th>Priority</th>
                        <th>Assignment</th>
                        <th class="text-end pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in Model)
                    {
                        <tr>
                            <td class="ps-4"><strong>#@ticket.TicketId</strong></td>
                            <td>@ticket.Title</td>
                            <td>@ticket.User?.FullName</td>
                            <td>
                                @{
                                    var statusClass = ticket.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.Open ? "primary" :
                                                     ticket.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.InProgress ? "warning" : "success";
                                }
                                <span class="badge bg-@statusClass bg-opacity-10 text-@statusClass px-2">@ticket.Status</span>
                            </td>
                            <td>
                                @{
                                    var priorityClass = ticket.Priority == TicketingSystem_DotNetMVC.Models.TicketPriority.High ? "danger" :
                                                       ticket.Priority == TicketingSystem_DotNetMVC.Models.TicketPriority.Medium ? "warning" : "info";
                                }
                                <span class="badge bg-@priorityClass bg-opacity-10 text-@priorityClass px-2">@ticket.Priority</span>
                            </td>
                            <td>
                                @if (ticket.AssignedAgentId == null)
                                {
                                    <span class="text-danger fw-bold"><i class="fas fa-exclamation-triangle me-1"></i>Unassigned</span>
                                }
                                else
                                {
                                    <span class="text-success"><i class="fas fa-user-check me-1"></i>Assigned to You</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a href="/Agent/TicketDetails/@ticket.TicketId" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                    <i class="fas fa-eye me-1"></i>View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
