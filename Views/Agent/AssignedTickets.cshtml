@{
    ViewData["Title"] = "Assigned Tickets";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0 page-title">Assigned Tickets</h3>
    <a href="/Agent/Dashboard" class="btn btn-outline-secondary btn-sm">Back</a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Search Tickets</label>
                <input class="form-control" placeholder="Search by title or ID" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select class="form-select">
                    <option>All</option>
                    <option>Open</option>
                    <option>In Progress</option>
                    <option>Closed</option>
                </select>
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button class="btn btn-primary w-100"><i class="fas fa-filter me-1"></i>Apply</button>
                <button class="btn btn-outline-secondary w-100"><i class="fas fa-rotate-left me-1"></i>Reset</button>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-list-check text-primary me-2"></i>Tickets Queue</h5>
        <span class="badge bg-secondary">1 Assigned</span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th>Ticket ID</th>
                    <th>Title</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Update Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>#AG-201</td>
                    <td>Scanner configuration</td>
                    <td><span class="badge bg-info text-dark">Low</span></td>
                    <td><span class="badge status-open">Open</span></td>
                    <td>
                        <select class="form-select form-select-sm">
                            <option>Open</option>
                            <option selected>In Progress</option>
                            <option>Closed</option>
                        </select>
                    </td>
                    <td><a href="/Agent/TicketDetails" class="btn btn-sm btn-outline-primary">View</a></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
