@model TicketingSystem_DotNetMVC.Models.Ticket
@{
    ViewData["Title"] = "Agent Ticket Details";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="page-title"><i class="fas fa-ticket-alt text-primary me-2"></i>Ticket #@Model.TicketId</h1>
            <p class="page-subtitle">Managing issue for user: <strong>@Model.User?.FullName</strong></p>
        </div>
        <a href="/Agent/Dashboard" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to Dashboard
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold">Ticket Details</h5>
                </div>
                <div class="card-body p-4">
                    <h4 class="mb-3">@Model.Title</h4>
                    
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded-3">
                                <small class="text-muted d-block">Priority</small>
                                @{
                                    var pClass = Model.Priority == TicketingSystem_DotNetMVC.Models.TicketPriority.High ? "danger" :
                                                Model.Priority == TicketingSystem_DotNetMVC.Models.TicketPriority.Medium ? "warning" : "info";
                                }
                                <span class="badge bg-@pClass mt-1">@Model.Priority</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded-3">
                                <small class="text-muted d-block">Status</small>
                                @{
                                    var sClass = Model.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.Open ? "primary" :
                                                Model.Status == TicketingSystem_DotNetMVC.Models.TicketStatus.InProgress ? "warning" : "success";
                                }
                                <span class="badge bg-@sClass mt-1">@Model.Status</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded-3">
                                <small class="text-muted d-block">Created</small>
                                <div class="fw-bold mt-1 small">@Model.CreatedDate.ToString("MMM dd, yyyy")</div>
                            </div>
                        </div>
                    </div>

                    <h6 class="fw-bold mb-2">Description</h6>
                    <div class="p-3 border rounded-3 bg-white mb-4">
                        <p class="mb-0" style="white-space: pre-wrap;">@Model.Description</p>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Attachments))
                    {
                        <h6 class="fw-bold mb-2">Attachment</h6>
                        <div class="mb-4">
                            <a href="@Model.Attachments" target="_blank">
                                <img src="@Model.Attachments" class="img-fluid rounded border shadow-sm" style="max-height: 400px;" alt="User Uploaded Image" />
                            </a>
                        </div>
                    }

                    <hr>

                    <h6 class="fw-bold mb-3">Add Internal Update / Comment</h6>
                    <form method="post" asp-action="AddComment" asp-controller="Dashboard">
                        <input type="hidden" name="ticketId" value="@Model.TicketId" />
                        <div class="mb-3">
                            <textarea name="message" class="form-control" rows="3" placeholder="Write your message to the user..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary px-4">Post Message</button>
                    </form>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold">Conversation History</h5>
                </div>
                <div class="card-body p-4 pt-0">
                    <div class="list-group list-group-flush">
                        @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedDate))
                        {
                            <div class="list-group-item px-0 py-3 border-0">
                                <div class="d-flex gap-3">
                                    <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-circle" style="width: 40px; height: 40px; text-align: center;">
                                        <i class="fas fa-user small"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <span class="fw-bold">@comment.User?.FullName</span>
                                            <small class="text-muted">@comment.CreatedDate.ToString("MMM dd, hh:mm tt")</small>
                                        </div>
                                        <p class="mb-0 text-secondary small">@comment.Message</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm sticky-top" style="top: 20px;">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold">Update Ticket Status</h5>
                </div>
                <div class="card-body p-4 pt-0">
                    <form asp-action="UpdateTicketStatus" method="post">
                        <input type="hidden" name="ticketId" value="@Model.TicketId" />
                        <div class="mb-3">
                            <label class="form-label small text-muted">Select New Status</label>
                            <select name="status" class="form-select">
                                @foreach (var status in Enum.GetValues(typeof(TicketingSystem_DotNetMVC.Models.TicketStatus)))
                                {
                                    <option value="@status" selected="@(Model.Status.ToString() == status.ToString())">@status</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Update Status</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>