@{
    ViewData["Title"] = "Agent Ticket Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0 page-title">Ticket Details</h3>
    <a href="/Agent/AssignedTickets" class="btn btn-outline-secondary btn-sm">Back</a>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card mb-3">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-circle-info me-2"></i>Ticket Information</h5>
            </div>
            <div class="card-body">
                <h5 class="mb-2">Scanner configuration</h5>
                <p class="text-secondary">Scanner not detected in POS software.</p>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="small text-secondary">Status</div>
                        <span class="badge status-progress">In Progress</span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Update Status</label>
                        <select class="form-select">
                            <option>Open</option>
                            <option selected>In Progress</option>
                            <option>Closed</option>
                        </select>
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <button class="btn btn-primary w-100">Save</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">Comments</div>
            <div class="card-body">
                <div class="border rounded p-3 mb-2 bg-light">User: Please resolve before store opening.</div>
                <div class="border rounded p-3 mb-3 bg-light">Agent: Driver update in progress.</div>
                <div class="d-flex gap-2">
                    <input class="form-control" placeholder="Add comment" />
                    <button class="btn btn-primary">Post</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">Activity Timeline</div>
            <div class="card-body">
                <div class="timeline">
                    <div class="timeline-item">
                        <h6 class="mb-1">Ticket Assigned</h6>
                        <p class="text-muted mb-0 small">Assigned to current agent queue.</p>
                    </div>
                    <div class="timeline-item">
                        <h6 class="mb-1">In Progress</h6>
                        <p class="text-muted mb-0 small">Driver investigation initiated.</p>
                    </div>
                    <div class="timeline-item">
                        <h6 class="mb-1">Waiting Confirmation</h6>
                        <p class="text-muted mb-0 small">Pending hardware validation from store.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
