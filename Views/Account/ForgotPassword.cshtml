@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - TicketSphere</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <style>
        body {
            min-height: 100vh;
            margin: 0;
            background:
                radial-gradient(circle at 10% 10%, rgba(79, 70, 229, 0.18), transparent 35%),
                radial-gradient(circle at 90% 90%, rgba(6, 182, 212, 0.18), transparent 30%),
                #f9fafb;
            display: grid;
            place-items: center;
            font-family: "Inter", "Segoe UI", sans-serif;
        }

        .auth-card {
            width: 100%;
            max-width: 430px;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            box-shadow: 0 18px 38px rgba(17, 24, 39, 0.12);
            overflow: hidden;
        }

        .auth-card .card-body {
            padding: 2.5rem;
        }

        .form-control {
            border-radius: 12px;
            min-height: 46px;
            border: 1px solid #d1d5db;
        }

        .form-control:focus {
            border-color: rgba(79, 70, 229, 0.65);
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.12);
        }

        .btn-primary {
            background: #4f46e5;
            border-color: #4f46e5;
            border-radius: 12px;
            min-height: 46px;
            font-weight: 600;
        }

        .brand-logo {
            width: 58px;
            height: 58px;
            border-radius: 14px;
            margin: 0 auto 12px;
            display: grid;
            place-items: center;
            color: #4338ca;
            background: #e0e7ff;
            font-size: 1.4rem;
        }
    </style>
</head>
<body>
    <div class="card auth-card">
        <div class="card-body">
            <div class="text-center mb-4">
                <div class="brand-logo"><i class="fas fa-key"></i></div>
                <h4 class="fw-bold">Forgot Password?</h4>
                <p class="text-secondary small">Enter your email and we'll send you a link to reset your password.</p>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success border-0 shadow-sm small mb-4">
                    <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                </div>
            }

            <form method="post">
                @Html.AntiForgeryToken()
                <div class="mb-4">
                    <label class="form-label">Email Address</label>
                    <input type="email" name="email" class="form-control" placeholder="name@company.com" required />
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary">Send Reset Link</button>
                    <a asp-action="Login" class="btn btn-link text-decoration-none small">Back to Login</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>