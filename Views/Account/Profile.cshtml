@model TicketingSystem_DotNetMVC.Models.User
@{
    ViewData["Title"] = "My Profile - TicketSphere";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-4">
                    <div>
                        <h3 class="mb-0"><i class="fas fa-user-circle"></i> My Profile</h3>
                    </div>
                    <a href="@Url.Action("Dashboard", "Dashboard")" class="btn btn-outline-light btn-sm">
                        <i class="fas fa-arrow-left"></i> Back to Dashboard
                    </a>
                </div>
                <div class="card-body p-5">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle"></i> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form method="post" asp-action="UpdateProfile" asp-controller="Account">
                        <input type="hidden" name="userId" value="@Model.UserId">

                        <div class="mb-4">
                            <label class="form-label fw-bold">Full Name</label>
                            <input type="text" name="fullName" class="form-control form-control-lg" value="@Model.FullName" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Email Address</label>
                            <input type="email" class="form-control form-control-lg" value="@Model.Email" disabled>
                            <small class="text-muted">Email cannot be changed</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Role</label>
                            <input type="text" class="form-control form-control-lg" value="@Model.Role" disabled>
                        </div>

                        <hr>

                        <div class="mb-4 text-muted small">
                            <i class="fas fa-clock"></i> <strong>Last Login:</strong> @(Model.LastLoginDate?.ToString("dd MMM yyyy, hh:mm tt") ?? "Never")
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save"></i> Save Changes
                            </button>
                            <a href="@Url.Action("Dashboard", "Dashboard")" class="btn btn-secondary btn-lg">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-bold {
        font-weight: 600;
    }
</style>
